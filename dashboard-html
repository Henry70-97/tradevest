<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>BestPay - User Dashboard</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <script type="module">
        import { initializeApp } from "https://www.gstatic.com/firebasejs/10.8.0/firebase-app.js";
        import { getAuth, onAuthStateChanged, signOut } from "https://www.gstatic.com/firebasejs/10.8.0/firebase-auth.js";
        import { getFirestore, doc, getDoc, updateDoc, increment, serverTimestamp } from "https://www.gstatic.com/firebasejs/10.8.0/firebase-firestore.js";
        
        const firebaseConfig = {
            apiKey: "AIzaSyDtGN7KCK0A4fhztLN0CgxsKkGROcO_-vI",
            authDomain: "bestpay-5b78c.firebaseapp.com",
            projectId: "bestpay-5b78c",
            storageBucket: "bestpay-5b78c.firebasestorage.app",
            messagingSenderId: "583230068716",
            appId: "1:583230068716:web:3e8d298b4d00b46c8652c9"
        };
        
        const app = initializeApp(firebaseConfig);
        const auth = getAuth(app);
        const db = getFirestore(app);
        
        let currentUser = null;
        
        onAuthStateChanged(auth, async (user) => {
            if (!user) {
                window.location.href = "registration.html";
                return;
            }
            
            currentUser = user;
            const userDoc = await getDoc(doc(db, "users", user.uid));
            if (!userDoc.exists()) {
                window.location.href = "registration.html";
                return;
            }
            
            const userData = userDoc.data();
            if (userData.role === "admin") {
                window.location.href = "admin.html";
                return;
            }
            
            // Display user info
            document.getElementById('userName').innerText = userData.displayName || user.email;
            document.getElementById('userEmail').innerText = user.email;
            document.getElementById('balanceAmount').innerText = `$${(userData.withdrawableBalance || 0).toFixed(2)}`;
            document.getElementById('referralCode').innerText = userData.referralCode || 'N/A';
            
            // Load wallet data
            const walletDoc = await getDoc(doc(db, "wallets", user.uid));
            if (walletDoc.exists()) {
                const walletData = walletDoc.data();
                document.getElementById('investedBalance').innerText = `$${(walletData.investedBalance || 0).toFixed(2)}`;
                document.getElementById('bonusBalance').innerText = `$${(walletData.bonusBalance || 0).toFixed(2)}`;
            }
        });
        
        window.logout = async () => {
            await signOut(auth);
            window.location.href = "registration.html";
        };
        
        window.showNotification = (message, type) => {
            const notification = document.createElement('div');
            notification.className = `fixed bottom-4 right-4 z-50 px-6 py-3 rounded-lg shadow-lg text-white ${type === 'success' ? 'bg-green-500' : 'bg-red-500'}`;
            notification.innerHTML = `<i class="fas ${type === 'success' ? 'fa-check-circle' : 'fa-exclamation-circle'} mr-2"></i>${message}`;
            document.body.appendChild(notification);
            setTimeout(() => notification.remove(), 3000);
        };
        
        window.copyReferralCode = () => {
            const code = document.getElementById('referralCode').innerText;
            navigator.clipboard.writeText(code);
            showNotification('Referral code copied!', 'success');
        };
    </script>
</head>
<body class="bg-gray-100">
    <div class="min-h-screen">
        <!-- Header -->
        <header class="bg-gradient-to-r from-blue-600 to-indigo-700 text-white shadow-lg">
            <div class="container mx-auto px-4 py-4 flex justify-between items-center">
                <div class="flex items-center gap-3">
                    <i class="fas fa-wallet text-2xl text-yellow-300"></i>
                    <h1 class="text-xl font-bold">BestPay Dashboard</h1>
                </div>
                <div class="flex items-center gap-4">
                    <span><i class="fas fa-user mr-2"></i><span id="userName">User</span></span>
                    <button onclick="logout()" class="bg-red-600 hover:bg-red-700 px-4 py-2 rounded-lg transition">
                        <i class="fas fa-sign-out-alt mr-2"></i>Logout
                    </button>
                </div>
            </div>
        </header>
        
        <div class="container mx-auto px-4 py-6">
            <!-- Welcome Card -->
            <div class="bg-white rounded-xl shadow-md p-6 mb-6">
                <h2 class="text-2xl font-bold text-gray-800">Welcome back, <span id="userNameDisplay">User</span>!</h2>
                <p class="text-gray-600">Email: <span id="userEmail">loading...</span></p>
            </div>
            
            <!-- Balance Cards -->
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-6">
                <div class="bg-gradient-to-r from-green-500 to-emerald-600 rounded-xl shadow-md p-6 text-white">
                    <div class="flex items-center justify-between">
                        <div>
                            <p class="text-sm opacity-90">Available Balance</p>
                            <p class="text-3xl font-bold" id="balanceAmount">$0.00</p>
                        </div>
                        <i class="fas fa-dollar-sign text-4xl opacity-50"></i>
                    </div>
                </div>
                <div class="bg-gradient-to-r from-blue-500 to-blue-600 rounded-xl shadow-md p-6 text-white">
                    <div class="flex items-center justify-between">
                        <div>
                            <p class="text-sm opacity-90">Invested Balance</p>
                            <p class="text-3xl font-bold" id="investedBalance">$0.00</p>
                        </div>
                        <i class="fas fa-chart-line text-4xl opacity-50"></i>
                    </div>
                </div>
                <div class="bg-gradient-to-r from-purple-500 to-purple-600 rounded-xl shadow-md p-6 text-white">
                    <div class="flex items-center justify-between">
                        <div>
                            <p class="text-sm opacity-90">Bonus Balance</p>
                            <p class="text-3xl font-bold" id="bonusBalance">$0.00</p>
                        </div>
                        <i class="fas fa-gift text-4xl opacity-50"></i>
                    </div>
                </div>
            </div>
            
            <!-- Referral Section -->
            <div class="bg-white rounded-xl shadow-md p-6">
                <h3 class="text-xl font-bold mb-4"><i class="fas fa-users text-blue-600 mr-2"></i>Your Referral Code</h3>
                <div class="flex items-center gap-4">
                    <code class="bg-gray-100 px-4 py-2 rounded-lg text-lg font-mono" id="referralCode">Loading...</code>
                    <button onclick="copyReferralCode()" class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg transition">
                        <i class="fas fa-copy mr-2"></i>Copy
                    </button>
                </div>
                <p class="text-sm text-gray-600 mt-4">Share your referral code with friends! You'll earn 10% commission on their welcome bonus.</p>
            </div>
            
            <!-- Placeholder for more features -->
            <div class="mt-6 text-center text-gray-500 text-sm">
                <p>More features coming soon: Investment plans, withdrawal requests, transaction history, and more!</p>
            </div>
        </div>
    </div>
</body>
</html>
